                    <color key="textColor" white="0.66666666666666663" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </label>
                <stackView opaque="NO" contentMode="scaleToFill" distribution="fillEqually" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="btnStack">
                    <rect key="frame" x="20" y="720" width="353" height="48"/>
                    <subviews>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="buyBtn">
                            <rect key="frame" x="0.0" y="0.0" width="170.66666666666666" height="48"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="48" id="buyH"/>
                            </constraints>
                            <state key="normal" title="BUY"/>
