                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="sellBtn">
                            <rect key="frame" x="182.66666666666663" y="0.0" width="170.33333333333337" height="48"/>
