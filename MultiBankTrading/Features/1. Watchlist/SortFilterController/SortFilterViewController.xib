<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="23504" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="23484"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner" customClass="SortFilterViewController" customModule="MultiBankStockPrice" customModuleProvider="target">
            <connections>
                <outlet property="view" destination="mainV" id="oView"/>
                <outlet property="priceHighBtn" destination="phBtn" id="oPH"/>
                <outlet property="priceLowBtn" destination="plBtn" id="oPL"/>
                <outlet property="changeHighBtn" destination="chBtn" id="oCH"/>
                <outlet property="changeLowBtn" destination="clBtn" id="oCL"/>
                <outlet property="filterByButton" destination="filtBtn" id="oFB"/>
            </connections>
        </placeholder>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" userLabel="First Responder"/>
        <view contentMode="scaleToFill" id="mainV">
            <rect key="frame" x="0.0" y="0.0" width="393" height="420"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- Handle Bar -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="handleV" userLabel="Handle Bar">
                    <rect key="frame" x="176" y="10" width="40" height="5"/>
                    <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.30000001192092896" colorSpace="custom" customColorSpace="sRGB"/>
                    <constraints>
                        <constraint firstAttribute="width" constant="40" id="hW"/>
                        <constraint firstAttribute="height" constant="5" id="hH"/>
                    </constraints>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                            <real key="value" value="2.5"/>
                        </userDefinedRuntimeAttribute>
                        <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                </view>
                <!-- Title -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Sort / Filter" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="titleLbl">
                    <rect key="frame" x="20" y="35" width="120" height="24"/>
                    <fontDescription key="fontDescription" type="boldSystem" pointSize="20"/>
                    <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </label>
                <!-- SORT BY Header -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="SORT BY" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="sortHdr">
                    <rect key="frame" x="20" y="79" width="55" height="16"/>
                    <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="13"/>
                    <color key="textColor" red="1" green="1" blue="1" alpha="0.5" colorSpace="custom" customColorSpace="sRGB"/>
                </label>
                <!-- Stock Price label -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Stock Price" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="stockLbl">
                    <rect key="frame" x="20" y="111" width="85" height="18"/>
                    <fontDescription key="fontDescription" type="system" weight="medium" pointSize="15"/>
                    <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </label>
                <!-- Price chip stack -->
                <stackView opaque="NO" contentMode="scaleToFill" axis="horizontal" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="pStack">
                    <rect key="frame" x="20" y="139" width="240" height="34"/>
                    <subviews>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" tag="0" translatesAutoresizingMaskIntoConstraints="NO" id="phBtn">
                            <rect key="frame" x="0" y="0" width="114" height="34"/>
                            <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.10000000149011612" colorSpace="custom" customColorSpace="sRGB"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="34" id="phH"/>
                            </constraints>
                            <inset key="contentEdgeInsets" minX="20" minY="8" maxX="20" maxY="8"/>
                            <fontDescription key="fontDescription" type="system" weight="medium" pointSize="14"/>
                            <state key="normal" title="High to Low">
                                <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </state>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <real key="value" value="16"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <connections>
                                <action selector="chipTapped:" destination="-1" eventType="touchUpInside" id="phAct"/>
                            </connections>
                        </button>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" tag="1" translatesAutoresizingMaskIntoConstraints="NO" id="plBtn">
                            <rect key="frame" x="126" y="0" width="114" height="34"/>
                            <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.10000000149011612" colorSpace="custom" customColorSpace="sRGB"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="34" id="plH"/>
                            </constraints>
                            <inset key="contentEdgeInsets" minX="20" minY="8" maxX="20" maxY="8"/>
                            <fontDescription key="fontDescription" type="system" weight="medium" pointSize="14"/>
                            <state key="normal" title="Low to High">
                                <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </state>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <real key="value" value="16"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <connections>
                                <action selector="chipTapped:" destination="-1" eventType="touchUpInside" id="plAct"/>
                            </connections>
                        </button>
                    </subviews>
                </stackView>
                <!-- Price Change label -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="Price Change" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="chgLbl">
                    <rect key="frame" x="20" y="193" width="100" height="18"/>
                    <fontDescription key="fontDescription" type="system" weight="medium" pointSize="15"/>
                    <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                </label>
                <!-- Change chip stack -->
                <stackView opaque="NO" contentMode="scaleToFill" axis="horizontal" spacing="12" translatesAutoresizingMaskIntoConstraints="NO" id="cStack">
                    <rect key="frame" x="20" y="221" width="240" height="34"/>
                    <subviews>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" tag="2" translatesAutoresizingMaskIntoConstraints="NO" id="chBtn">
                            <rect key="frame" x="0" y="0" width="114" height="34"/>
                            <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.10000000149011612" colorSpace="custom" customColorSpace="sRGB"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="34" id="chH"/>
                            </constraints>
                            <inset key="contentEdgeInsets" minX="20" minY="8" maxX="20" maxY="8"/>
                            <fontDescription key="fontDescription" type="system" weight="medium" pointSize="14"/>
                            <state key="normal" title="High to Low">
                                <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </state>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <real key="value" value="16"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <connections>
                                <action selector="chipTapped:" destination="-1" eventType="touchUpInside" id="chAct"/>
                            </connections>
                        </button>
                        <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" tag="3" translatesAutoresizingMaskIntoConstraints="NO" id="clBtn">
                            <rect key="frame" x="126" y="0" width="114" height="34"/>
                            <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.10000000149011612" colorSpace="custom" customColorSpace="sRGB"/>
                            <constraints>
                                <constraint firstAttribute="height" constant="34" id="clH"/>
                            </constraints>
                            <inset key="contentEdgeInsets" minX="20" minY="8" maxX="20" maxY="8"/>
                            <fontDescription key="fontDescription" type="system" weight="medium" pointSize="14"/>
                            <state key="normal" title="Low to High">
                                <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            </state>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <real key="value" value="16"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <connections>
                                <action selector="chipTapped:" destination="-1" eventType="touchUpInside" id="clAct"/>
                            </connections>
                        </button>
                    </subviews>
                </stackView>
                <!-- Separator -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="sepV" userLabel="Separator">
                    <rect key="frame" x="20" y="283" width="353" height="1"/>
                    <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.079999998211860657" colorSpace="custom" customColorSpace="sRGB"/>
                    <constraints>
                        <constraint firstAttribute="height" constant="0.5" id="sepH"/>
                    </constraints>
                </view>
                <!-- FILTER BY Header -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" text="FILTER BY" textAlignment="natural" lineBreakMode="tailTruncation" baselineAdjustment="alignBaselines" adjustsFontSizeToFit="NO" translatesAutoresizingMaskIntoConstraints="NO" id="filtHdr">
                    <rect key="frame" x="20" y="308" width="65" height="16"/>
                    <fontDescription key="fontDescription" type="system" weight="semibold" pointSize="13"/>
                    <color key="textColor" red="1" green="1" blue="1" alpha="0.5" colorSpace="custom" customColorSpace="sRGB"/>
                </label>
                <!-- Filter By Button -->
                <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="system" lineBreakMode="middleTruncation" translatesAutoresizingMaskIntoConstraints="NO" id="filtBtn">
                    <rect key="frame" x="20" y="340" width="100" height="34"/>
                    <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.10000000149011612" colorSpace="custom" customColorSpace="sRGB"/>
                    <constraints>
                        <constraint firstAttribute="height" constant="34" id="fbH"/>
                    </constraints>
                    <inset key="contentEdgeInsets" minX="20" minY="8" maxX="20" maxY="8"/>
                    <fontDescription key="fontDescription" type="system" weight="medium" pointSize="15"/>
                    <state key="normal" title="Filter By">
                        <color key="titleColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    </state>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                            <real key="value" value="16"/>
                        </userDefinedRuntimeAttribute>
                        <userDefinedRuntimeAttribute type="boolean" keyPath="clipsToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                    <connections>
                        <action selector="filterByTapped" destination="-1" eventType="touchUpInside" id="fbAct"/>
                    </connections>
                </button>
            </subviews>
            <color key="backgroundColor" red="0.11764705882352941" green="0.11764705882352941" blue="0.11764705882352941" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
            <constraints>
                <constraint firstItem="handleV" firstAttribute="top" secondItem="mainV" secondAttribute="top" constant="10" id="c01"/>
                <constraint firstItem="handleV" firstAttribute="centerX" secondItem="mainV" secondAttribute="centerX" id="c02"/>
                <constraint firstItem="titleLbl" firstAttribute="top" secondItem="handleV" secondAttribute="bottom" constant="20" id="c03"/>
                <constraint firstItem="titleLbl" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c04"/>
                <constraint firstItem="sortHdr" firstAttribute="top" secondItem="titleLbl" secondAttribute="bottom" constant="28" id="c05"/>
                <constraint firstItem="sortHdr" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c06"/>
                <constraint firstItem="stockLbl" firstAttribute="top" secondItem="sortHdr" secondAttribute="bottom" constant="16" id="c07"/>
                <constraint firstItem="stockLbl" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c08"/>
                <constraint firstItem="pStack" firstAttribute="top" secondItem="stockLbl" secondAttribute="bottom" constant="10" id="c09"/>
                <constraint firstItem="pStack" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c10"/>
                <constraint firstItem="chgLbl" firstAttribute="top" secondItem="pStack" secondAttribute="bottom" constant="20" id="c11"/>
                <constraint firstItem="chgLbl" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c12"/>
                <constraint firstItem="cStack" firstAttribute="top" secondItem="chgLbl" secondAttribute="bottom" constant="10" id="c13"/>
                <constraint firstItem="cStack" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c14"/>
                <constraint firstItem="sepV" firstAttribute="top" secondItem="cStack" secondAttribute="bottom" constant="28" id="c15"/>
                <constraint firstItem="sepV" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c16"/>
                <constraint firstAttribute="trailing" secondItem="sepV" secondAttribute="trailing" constant="20" id="c17"/>
                <constraint firstItem="filtHdr" firstAttribute="top" secondItem="sepV" secondAttribute="bottom" constant="24" id="c18"/>
                <constraint firstItem="filtHdr" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c19"/>
                <constraint firstItem="filtBtn" firstAttribute="top" secondItem="filtHdr" secondAttribute="bottom" constant="16" id="c20"/>
                <constraint firstItem="filtBtn" firstAttribute="leading" secondItem="mainV" secondAttribute="leading" constant="20" id="c21"/>
            </constraints>
            <viewLayoutGuide key="safeArea" id="safeArea"/>
        </view>
    </objects>
</document>
